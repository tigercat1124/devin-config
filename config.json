{
  "version": 1,
  "shell": {
    "setup_complete": true
  },
  "theme_mode": "dark",
  "agent": {
    "model": "glm-5-2"
  },
  "permissions": {
    "allow": [
      "Fetch(domain:github.com)",
      "Fetch(domain:cli.devin.ai)",
      "Write(~/.config/devin/skills/dig)",
      "Fetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Exec(sudo)",
      "Exec(mkfs)",
      "Exec(dd if=/dev/zero of=/dev/sd",
      "Exec(dd if=/dev/zero of=/dev/nvm",
      "Exec(dd if=/dev/zero of=/dev/disk",
      "Exec(dd if=/dev/zero of=/dev/vd",
      "Exec(dd if=/dev/zero of=/dev/xvd",
      "Exec(dd if=/dev/random of=/dev/sd",
      "Exec(dd if=/dev/random of=/dev/nvm",
      "Exec(dd if=/dev/urandom of=/dev/sd",
      "Exec(dd if=/dev/urandom of=/dev/nvm",
      "Exec(chmod -R 777 /)",
      "Exec(chmod -R 777 ~)",
      "Exec(chmod -R 777 $HOME)",
      "Exec(rm -rf --no-preserve-root)",
      "Exec(rm -rf --no-preserve-root /)",
      "Exec(git push --force origin main)",
      "Exec(git push --force origin master)",
      "Exec(git push -f origin main)",
      "Exec(git push -f origin master)",
      "Exec(git push --force origin HEAD)",
      "Exec(git push -f origin HEAD)",
      "Exec(git push --delete origin main)",
      "Exec(git push --delete origin master)",
      "Write(~/.ssh/**)",
      "Write(**/.ssh/**)",
      "Write(~/.aws/credentials)",
      "Write(~/.aws/config)",
      "Write(~/.gnupg/**)",
      "Write(**/.git/hooks/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ],
    "ask": [
      "Exec(rm -rf)",
      "Exec(rm -r)",
      "Exec(git push --force)",
      "Exec(git push -f)",
      "Exec(git push --delete)",
      "Exec(git reset --hard)",
      "Exec(git clean -fd)",
      "Exec(git branch -D)",
      "Exec(git rebase)",
      "Exec(chmod)",
      "Exec(chown)",
      "Exec(pkill)",
      "Exec(killall)",
      "Exec(systemctl)",
      "Exec(service)",
      "Exec(docker rm)",
      "Exec(docker rmi)",
      "Exec(docker volume rm)",
      "Exec(docker system prune)",
      "Exec(kubectl delete)",
      "Exec(kubectl scale)",
      "Exec(kubectl apply)",
      "Exec(helm uninstall)",
      "Exec(helm delete)",
      "Exec(terraform destroy)",
      "Exec(npm publish)",
      "Exec(pip install)",
      "Exec(pip3 install)",
      "Exec(pipx install)",
      "Exec(brew install)",
      "Exec(apt install)",
      "Exec(apt-get install)",
      "Exec(yum install)",
      "Exec(dnf install)",
      "Exec(cargo install)",
      "Exec(go install)",
      "Exec(make install)",
      "Exec(curl)",
      "Exec(wget)",
      "Write(**/.git/**)",
      "Write(**/package-lock.json)",
      "Write(**/yarn.lock)",
      "Write(**/pnpm-lock.yaml)",
      "Write(**/Cargo.lock)",
      "Write(**/go.sum)"
    ]
  },
  "auto_update": true,
  "respect_gitignore": true,
  "notify": "smart",
  "show_hints": false
}